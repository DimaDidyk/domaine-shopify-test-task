  },
  "homepage": "https://github.com/DimaDidyk/domaine-shopify-test-task#readme",
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "@tailwindcss/cli": "^4.2.4",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4"
  }
